{
  "name": "@consenttheater/website",
  "version": "0.9.0",
  "description": "ConsentTheater — open-source tracker lookup and project site. Built on Astro + Cloudflare Workers, powered by @consenttheater/playbill.",
  "type": "module",
  "private": true,
  "author": {
    "name": "ConsentTheater",
    "email": "developer@consenttheater.org",
    "url": "https://consenttheater.org"
  },
  "license": "AGPL-3.0-or-later",
  "homepage": "https://consenttheater.org",
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/ConsentTheater/website"
  },
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/generate-og.mjs",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "deploy": "npm run build && wrangler deploy",
    "og": "node scripts/generate-og.mjs",
    "cf:typegen": "wrangler types",
    "astro": "astro",
    "typecheck": "astro check",
    "test:a11y": "astro build && start-server-and-test \"astro preview --port 4321\" \"http-get://localhost:4321/\" \"node scripts/a11y.mjs\"",
    "test:a11y:dark": "astro build && start-server-and-test \"astro preview --port 4321\" \"http-get://localhost:4321/\" \"node scripts/a11y.mjs --theme=dark\"",
    "test:a11y:hc": "astro build && start-server-and-test \"astro preview --port 4321\" \"http-get://localhost:4321/\" \"node scripts/a11y.mjs --contrast=high\"",
    "test:a11y:hc:dark": "astro build && start-server-and-test \"astro preview --port 4321\" \"http-get://localhost:4321/\" \"node scripts/a11y.mjs --theme=dark --contrast=high\"",
    "test:a11y:run": "node scripts/a11y.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@consenttheater/playbill": "^0.5.0",
    "@tailwindcss/vite": "^4.3.1",
    "@zachleat/table-saw": "^1.0.7",
    "astro": "^6.4.8",
    "@freshjuice/astro-webmcp": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "hono": "^4.12.25",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@fontsource/lora": "^5.2.8",
    "@iconify-json/ph": "^1.2.2",
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^25.9.3",
    "astro-icon": "^1.1.5",
    "astro-llms-md": "^2.2.1",
    "gray-matter": "^4.0.3",
    "pa11y-ci": "^4.1.1",
    "rehype-external-links": "^3.0.0",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "sharp": "^0.35.1",
    "start-server-and-test": "^3.0.11",
    "typescript": "^5.9.3",
    "wrangler": "^4.101.0"
  },
  "overrides": {
    "sharp": "$sharp"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
