---
import '@/styles/globals.css';
import { Image } from 'astro:assets';
import { execSync } from 'node:child_process';
import { SettingsDialog } from '@/components/SettingsDialog';
import logo from '@/assets/logo.png';

function readBuildInfo() {
  const builtAt = new Date().toISOString().slice(0, 10);
  try {
    const commit = execSync('git rev-parse --short HEAD', {
      encoding: 'utf8',
      stdio: ['ignore', 'pipe', 'ignore']
    }).trim();
    return { commit, builtAt };
  } catch {
    return { commit: null as string | null, builtAt };
  }
}

const { commit, builtAt } = readBuildInfo();

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'ConsentTheater — GDPR cookie & tracker lookup',
  description = 'Identify cookies, domains and trackers. Look up any cookie name or domain to see the company, service, category and severity.',
  image = '/og-default.png'
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const imageUrl = new URL(image, Astro.site).toString();

const year = new Date().getFullYear();
---
<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="ConsentTheater" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="628" />
    <meta property="og:image:alt" content={title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={title} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="ConsentTheater" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#24488f" />
    <meta name="color-scheme" content="light dark" />
    <script is:inline>
      (function () {
        try {
          var raw = localStorage.getItem('ct_settings');
          var s = raw ? JSON.parse(raw) : {};
          var theme = s.theme || 'system';
          var dark = theme === 'dark' ||
            (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
          if (dark) document.documentElement.classList.add('dark');

          var hc = s.highContrast;
          if (hc === true) hc = 'on';
          else if (hc === false) hc = 'off';
          else if (hc == null) hc = 'system';
          var useHc = hc === 'on' ||
            (hc === 'system' && window.matchMedia('(prefers-contrast: more)').matches);
          if (useHc) document.documentElement.classList.add('high-contrast');
        } catch (e) { /* localStorage unavailable — fall back to defaults */ }
      })();
    </script>
  </head>
  <body class="min-h-full bg-background text-foreground">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2"
    >
      Skip to main content
    </a>
    <div class="flex min-h-screen flex-col">
      <header class="border-b border-border bg-card">
        <div class="mx-auto flex w-full max-w-4xl items-center justify-between gap-3 px-6 py-4">
          <a href="/" class="flex items-center gap-3 transition-opacity hover:opacity-80" aria-label="ConsentTheater home">
            <Image
              src={logo}
              alt=""
              width={28}
              height={28}
              densities={[2, 3]}
              loading="eager"
              class="h-7 w-7 rounded-full"
              aria-hidden="true"
            />
            <div class="leading-tight">
              <p class="font-display text-base font-bold tracking-tight">ConsentTheater</p>
              <p class="text-[11px] font-semibold uppercase tracking-wider text-muted-foreground">Tracker lookup</p>
            </div>
          </a>
          <SettingsDialog client:load />
        </div>
      </header>

      <main id="main" class="flex-1">
        <slot />
      </main>

      <footer class="border-t border-border bg-card">
        <div class="mx-auto flex w-full max-w-4xl flex-wrap items-center justify-between gap-2 px-6 pb-1 pt-3 text-[11px] text-muted-foreground">
          <span>© {year} ConsentTheater · Non-commercial, open-source project <span class="whitespace-nowrap">(AGPL-3.0)</span></span>
          <nav class="flex items-center gap-4" aria-label="Footer">
            <a href="/about/" class="transition-colors hover:text-foreground">About</a>
            <a href="/privacy/" class="transition-colors hover:text-foreground">Privacy</a>
            <a href="/license/" class="transition-colors hover:text-foreground">License</a>
            <a
              href="https://github.com/ConsentTheater"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 transition-colors hover:text-foreground"
              aria-label="ConsentTheater on GitHub"
            >
              <svg viewBox="0 0 16 16" class="h-3.5 w-3.5" fill="currentColor" aria-hidden="true">
                <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
              </svg>
              GitHub
            </a>
          </nav>
        </div>
        <div class="mx-auto w-full max-w-4xl px-6 pb-3 text-[10px] text-muted-foreground/70">
          <span class="whitespace-nowrap">
            Build
            {' '}
            {commit ? (
              <a
                href={`https://github.com/ConsentTheater/website/commit/${commit}`}
                target="_blank"
                rel="noopener noreferrer"
                class="font-mono transition-colors hover:text-foreground"
              >{commit}</a>
            ) : (
              <span class="font-mono">dev</span>
            )}
            {' · '}
            <time datetime={builtAt} class="font-mono">{builtAt}</time>
          </span>
        </div>
      </footer>
    </div>
  </body>
</html>
