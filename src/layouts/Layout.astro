---
import '@/styles/globals.css';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { execSync } from 'node:child_process';
import { SettingsDialog } from '@/components/SettingsDialog';
import { ConsentBanner } from '@/components/ConsentBanner';
import logo from '@/assets/logo.png';

function readBuildInfo() {
  const builtAt = new Date().toISOString().slice(0, 10);
  try {
    const commit = execSync('git rev-parse --short HEAD', {
      encoding: 'utf8',
      stdio: ['ignore', 'pipe', 'ignore']
    }).trim();
    return { commit, builtAt };
  } catch {
    return { commit: null as string | null, builtAt };
  }
}

const { commit, builtAt } = readBuildInfo();

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'ConsentTheater — GDPR cookie & tracker lookup',
  description = 'Identify cookies, domains and trackers. Look up any cookie name or domain to see the company, service, category and consent burden under GDPR.',
  image = '/og-default.png'
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const imageUrl = new URL(image, Astro.site).toString();

const year = new Date().getFullYear();

const currentPath = Astro.url.pathname;
const navItems = [
  { href: '/', label: 'Lookup', mobileLabel: 'Check an Actor', mobileOnly: true },
  { href: '/methodology/', label: 'Methodology', mobileLabel: 'Our Methodology' },
  { href: '/extension/', label: 'Extension', mobileLabel: 'Free Browser Extension' },
  { href: '/about/', label: 'About', mobileLabel: 'About Project' }
];
const isActive = (href: string) =>
  href === '/'
    ? currentPath === '/'
    : currentPath === href || currentPath.startsWith(href);
---
<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="ConsentTheater" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="628" />
    <meta property="og:image:alt" content={title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={title} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="ConsentTheater" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#24488f" />
    <meta name="color-scheme" content="light dark" />
    <script is:inline>
      (function () {
        try {
          var raw = localStorage.getItem('ct_settings');
          var s = raw ? JSON.parse(raw) : {};
          var theme = s.theme || 'system';
          var dark = theme === 'dark' ||
            (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
          if (dark) document.documentElement.classList.add('dark');

          var hc = s.highContrast;
          if (hc === true) hc = 'on';
          else if (hc === false) hc = 'off';
          else if (hc == null) hc = 'system';
          var useHc = hc === 'on' ||
            (hc === 'system' && window.matchMedia('(prefers-contrast: more)').matches);
          if (useHc) document.documentElement.classList.add('high-contrast');
        } catch (e) { /* localStorage unavailable — fall back to defaults */ }
      })();
    </script>
  </head>
  <body class="min-h-full bg-background text-foreground">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2"
    >
      Skip to main content
    </a>
    <div class="flex min-h-screen flex-col">
      <header class="border-b border-border bg-card">
        <div class="mx-auto flex w-full max-w-4xl items-center justify-between gap-3 px-6 py-4">
          <a href="/" class="group flex items-center gap-3" aria-label="ConsentTheater home">
            <Image
              src={logo}
              alt=""
              width={36}
              height={36}
              densities={[2, 3]}
              loading="eager"
              class="h-9 w-9 rounded-full"
              aria-hidden="true"
            />
            <div class="leading-tight transition-opacity group-hover:opacity-80">
              <p class="font-display text-base font-bold tracking-tight">ConsentTheater</p>
              <p class="text-[11px] font-semibold uppercase tracking-wider text-muted-foreground">Tracker lookup</p>
            </div>
          </a>

          <div class="flex items-center gap-8">
            <nav aria-label="Primary" class="hidden sm:block">
              <ul class="flex items-center gap-5">
                {navItems.filter(item => !item.mobileOnly).map(item => (
                  <li>
                    <a
                      href={item.href}
                      class:list={[
                        'text-sm transition-colors hover:text-foreground',
                        isActive(item.href) ? 'font-semibold text-foreground' : 'text-muted-foreground'
                      ]}
                      aria-current={isActive(item.href) ? 'page' : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>

            <SettingsDialog client:load navItems={navItems} currentPath={currentPath} />
          </div>
        </div>
      </header>

      <main id="main" class="flex-1">
        <slot />
      </main>

      <footer class="border-t border-border bg-card">
        <div class="mx-auto grid w-full max-w-4xl gap-6 px-6 py-6 text-[11px] text-muted-foreground">
          <!-- 1. Menu -->
          <nav
            class="flex flex-col items-start gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:gap-x-5 sm:gap-y-2"
            aria-label="Footer"
          >
            <a href="/about/" class="py-1 transition-colors hover:text-foreground">About</a>
            <a href="/extension/" class="py-1 transition-colors hover:text-foreground">Extension</a>
            <a href="/methodology/" class="py-1 transition-colors hover:text-foreground">Methodology</a>
            <a href="/privacy/" class="py-1 transition-colors hover:text-foreground">Privacy</a>
            <a href="/license/" class="py-1 transition-colors hover:text-foreground">License</a>
            <a href="/acknowledgements/" class="py-1 transition-colors hover:text-foreground">Acknowledgements</a>
            <a href="/stats/" class="py-1 transition-colors hover:text-foreground">Stats</a>
            <button
              type="button"
              data-action="open-consent"
              class="cursor-pointer py-1 text-left transition-colors hover:text-foreground"
            >Cookie preferences</button>
            <a
              href="https://github.com/ConsentTheater"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 py-1 transition-colors hover:text-foreground"
              aria-label="ConsentTheater on GitHub"
            >
              <Icon name="ph:github-logo" class="h-3.5 w-3.5" aria-hidden="true" />
              GitHub
            </a>
          </nav>

          <!-- 2. Copyright & fine print -->
          <div class="grid gap-2">
            <span>
              © {year} ConsentTheater · Non-commercial, open-source project <span class="whitespace-nowrap">(AGPL-3.0)</span>
            </span>
            <p class="text-[10px] leading-relaxed text-muted-foreground/70">
              ConsentTheater is an independent, volunteer-run, non-commercial project.
              Content on this site is provided for educational purposes only and is
              not legal advice. Not affiliated with or endorsed by any regulator, law
              firm, browser vendor, or service listed in the catalogue. All trademarks
              and product names are the property of their respective owners.
            </p>
          </div>

          <!-- 3. Build -->
          <div class="text-[10px] text-muted-foreground/70">
            <span class="whitespace-nowrap">
              Build
              {' '}
              {commit ? (
                <a
                  href={`https://github.com/ConsentTheater/website/commit/${commit}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-mono transition-colors hover:text-foreground"
                >{commit}</a>
              ) : (
                <span class="font-mono">dev</span>
              )}
              {' · '}
              <time datetime={builtAt} class="font-mono">{builtAt}</time>
            </span>
          </div>
        </div>
      </footer>
    </div>

    <ConsentBanner client:load />

    <script is:inline>
      // Wire up the footer "Cookie preferences" button to dispatch the
      // event the ConsentBanner component listens for. Inline so it ships
      // without an extra island.
      document.addEventListener('click', function (e) {
        var target = e.target;
        if (!(target instanceof Element)) return;
        var btn = target.closest('[data-action="open-consent"]');
        if (!btn) return;
        e.preventDefault();
        window.dispatchEvent(new CustomEvent('ct:open-consent-banner'));
      });
    </script>
  </body>
</html>
