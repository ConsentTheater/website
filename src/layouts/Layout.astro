---
import '@/styles/globals.css';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { execSync } from 'node:child_process';
import SettingsDialog from '@/components/SettingsDialog.astro';
import CodebergCta from '@/components/CodebergCta.astro';
import { ogImagePath } from '@/utils/og';
import { baseNodes } from '@/utils/schema';
import logo from '@/assets/logo.png';

function readBuildInfo() {
  const builtAt = new Date().toISOString().slice(0, 10);
  try {
    const commit = execSync('git rev-parse --short HEAD', {
      encoding: 'utf8',
      stdio: ['ignore', 'pipe', 'ignore']
    }).trim();
    return { commit, builtAt };
  } catch {
    return { commit: null as string | null, builtAt };
  }
}

const { commit, builtAt } = readBuildInfo();

interface Props {
  title?: string;
  description?: string;
  image?: string;
  showCodebergCta?: boolean;
  markdownUrl?: string;
  schema?: Record<string, unknown>[];
}

const {
  title = 'ConsentTheater — GDPR cookie & tracker lookup',
  description = 'Identify cookies, domains and trackers. Look up any cookie name or domain to see the company, service, category and consent burden under GDPR.',
  image,
  showCodebergCta = true,
  markdownUrl,
  schema = []
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const imageUrl = new URL(image ?? ogImagePath(Astro.url.pathname), Astro.site).toString();

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [...baseNodes(Astro.site!), ...schema]
};

const year = new Date().getFullYear();

const currentPath = Astro.url.pathname;
const navItems = [
  { href: '/', label: 'Lookup', mobileLabel: 'Check an Actor', mobileOnly: true },
  { href: '/handbook/', label: 'Handbook', mobileLabel: 'Handbook' },
  { href: '/methodology/', label: 'Methodology', mobileLabel: 'Our Methodology' },
  { href: '/extension/', label: 'Extension', mobileLabel: 'Free Browser Extension' },
  { href: '/about/', label: 'About', mobileLabel: 'About Project' }
];
const isActive = (href: string) =>
  href === '/'
    ? currentPath === '/'
    : currentPath === href || currentPath.startsWith(href);
---
<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
    {markdownUrl && (
      <link rel="alternate" type="text/markdown" href={markdownUrl} title="Markdown version (for LLMs)" />
    )}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="ConsentTheater" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="628" />
    <meta property="og:image:alt" content={title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={title} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="ConsentTheater" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#24488f" />
    <meta name="color-scheme" content="light dark" />
    <script is:inline>
      (function () {
        try {
          var raw = localStorage.getItem('consenttheater.preferences');
          var s = raw ? JSON.parse(raw) : {};
          var theme = s.theme || 'system';
          var dark = theme === 'dark' ||
            (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
          if (dark) document.documentElement.classList.add('dark');

          var hc = s.highContrast;
          if (hc === true) hc = 'on';
          else if (hc === false) hc = 'off';
          else if (hc == null) hc = 'system';
          var useHc = hc === 'on' ||
            (hc === 'system' && window.matchMedia('(prefers-contrast: more)').matches);
          if (useHc) document.documentElement.classList.add('high-contrast');
        } catch (e) { /* localStorage unavailable — fall back to defaults */ }
      })();
    </script>
    <script type="speculationrules" is:inline set:html={JSON.stringify({
      prerender: [{
        where: {
          and: [
            { href_matches: '/*' },
            { not: { href_matches: '/api/*' } },
            { not: { selector_matches: '[rel~="external"]' } },
            { not: { selector_matches: '[target="_blank"]' } }
          ]
        },
        eagerness: 'moderate'
      }]
    })} />
  </head>
  <body class="min-h-full bg-background text-foreground">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2"
    >
      Skip to main content
    </a>
    <div class="flex min-h-screen flex-col">
      <header class="border-b border-border bg-card">
        <div class="mx-auto flex w-full max-w-4xl items-center justify-between gap-3 px-6 py-4">
          <a href="/" class="group flex items-center gap-3" aria-label="ConsentTheater home">
            <Image
              src={logo}
              alt=""
              width={36}
              height={36}
              densities={[2, 3]}
              loading="eager"
              class="h-9 w-9 rounded-full"
              aria-hidden="true"
            />
            <div class="leading-tight transition-opacity group-hover:opacity-80">
              <p class="font-display text-base font-bold tracking-tight">ConsentTheater</p>
              <p class="text-[11px] font-semibold uppercase tracking-wider text-muted-foreground">Tracker lookup</p>
            </div>
          </a>

          <div class="flex items-center gap-8">
            <nav aria-label="Primary" class="hidden sm:block">
              <ul class="flex items-center gap-5">
                {navItems.filter(item => !item.mobileOnly).map(item => (
                  <li>
                    <a
                      href={item.href}
                      class:list={[
                        'text-sm transition-colors hover:text-foreground',
                        isActive(item.href) ? 'font-semibold text-foreground' : 'text-muted-foreground'
                      ]}
                      aria-current={isActive(item.href) ? 'page' : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>

            <SettingsDialog navItems={navItems} currentPath={currentPath} />
          </div>
        </div>
      </header>

      <main id="main" class="flex-1">
        <slot />
      </main>

      {showCodebergCta && (
        <aside class="mx-auto w-full max-w-3xl px-6 pb-12">
          <CodebergCta />
        </aside>
      )}

      <footer class="border-t border-border bg-card" aria-label="Footer">
        <div class="mx-auto w-full max-w-4xl px-6 py-10 text-[11px] text-muted-foreground">
          <!-- Top: brand + link columns -->
          <div class="grid grid-cols-2 gap-x-6 gap-y-8 md:grid-cols-4">
            <!-- Brand + social -->
            <div class="col-span-2 flex flex-col gap-3 md:col-span-1">
              <a
                href="/"
                class="inline-flex items-center gap-2 text-foreground transition-opacity hover:opacity-80"
                aria-label="ConsentTheater home"
              >
                <Image
                  src={logo}
                  alt=""
                  width={28}
                  height={28}
                  densities={[2, 3]}
                  class="h-7 w-7 rounded-full"
                  aria-hidden="true"
                />
                <span class="font-display text-sm font-bold tracking-tight">ConsentTheater</span>
              </a>
              <p class="leading-relaxed">
                Independent, open-source project documenting cookies, trackers and
                consent under GDPR.
              </p>
              <div class="mt-1 flex items-center gap-4">
                <a
                  href="https://codeberg.org/ConsentTheater"
                  target="_blank"
                  rel="noopener"
                  class="transition-colors hover:text-foreground"
                  aria-label="ConsentTheater on Codeberg"
                >
                  <Icon name="codeberg" class="h-5 w-5" aria-hidden="true" />
                </a>
                <a
                  href="https://github.com/ConsentTheater"
                  target="_blank"
                  rel="noopener"
                  class="transition-colors hover:text-foreground"
                  aria-label="ConsentTheater read-only mirror on GitHub"
                >
                  <Icon name="github" class="h-5 w-5" aria-hidden="true" />
                </a>
                <a
                  href="https://www.linkedin.com/company/consenttheater"
                  target="_blank"
                  rel="noopener"
                  class="transition-colors hover:text-foreground"
                  aria-label="ConsentTheater on LinkedIn"
                >
                  <Icon name="linkedin" class="h-5 w-5" aria-hidden="true" />
                </a>
              </div>
            </div>

            <!-- Law -->
            <nav class="flex flex-col gap-2.5" aria-label="Law references">
              <h2 class="font-semibold uppercase tracking-wider text-foreground">Law</h2>
              <a href="/law/gdpr/art-6/" class="text-[13px] transition-colors hover:text-foreground">GDPR Art. 6 — Lawful bases</a>
              <a href="/law/gdpr/art-7/" class="text-[13px] transition-colors hover:text-foreground">GDPR Art. 7 — Consent</a>
              <a href="/law/gdpr/art-17/" class="text-[13px] transition-colors hover:text-foreground">GDPR Art. 17 — Right to erasure</a>
              <a href="/law/eprivacy/art-5/" class="text-[13px] transition-colors hover:text-foreground">ePrivacy Art. 5 — Cookies</a>
              <a href="/law/uk-gdpr-and-pecr/" class="text-[13px] transition-colors hover:text-foreground">UK GDPR &amp; PECR</a>
              <a href="/law/" class="text-[13px] transition-colors hover:text-foreground">All law references</a>
            </nav>

            <!-- Handbook -->
            <nav class="flex flex-col gap-2.5" aria-label="Handbook">
              <h2 class="font-semibold uppercase tracking-wider text-foreground">Handbook</h2>
              <a href="/handbook/" class="text-[13px] transition-colors hover:text-foreground">All guides</a>
              <a href="/handbook/strict-necessary-cookies/" class="text-[13px] transition-colors hover:text-foreground">Strict-necessary cookies</a>
              <a href="/handbook/tracking-pixels/" class="text-[13px] transition-colors hover:text-foreground">Tracking pixels</a>
              <a href="/handbook/privacy-friendly-browsers/" class="text-[13px] transition-colors hover:text-foreground">Privacy-friendly browsers</a>
              <a href="/handbook/dns-sinkholes/" class="text-[13px] transition-colors hover:text-foreground">DNS sinkholes</a>
            </nav>

            <!-- Project -->
            <nav class="flex flex-col gap-2.5" aria-label="Project">
              <h2 class="font-semibold uppercase tracking-wider text-foreground">Project</h2>
              <a href="/extension/" class="text-[13px] transition-colors hover:text-foreground">Browser extension</a>
              <a href="/methodology/" class="text-[13px] transition-colors hover:text-foreground">Methodology</a>
              <a href="/about/" class="text-[13px] transition-colors hover:text-foreground">About</a>
              <a href="/privacy/" class="text-[13px] transition-colors hover:text-foreground">Privacy</a>
              <a href="/license/" class="text-[13px] transition-colors hover:text-foreground">License</a>
              <a href="/acknowledgements/" class="text-[13px] transition-colors hover:text-foreground">Acknowledgements</a>
            </nav>
          </div>

          <!-- Bottom: copyright, fine print, then build as the final line -->
          <div class="mt-10 grid gap-3 border-t border-border pt-6">
            <span>
              © {year} ConsentTheater · Non-commercial, open-source project <span class="whitespace-nowrap">(AGPL-3.0)</span>
            </span>
            <p class="leading-relaxed">
              ConsentTheater is an independent, volunteer-run, non-commercial project.
              Content on this site is provided for educational purposes only and is
              not legal advice. Not affiliated with or endorsed by any regulator, law
              firm, browser vendor, or service listed in the catalogue. All trademarks
              and product names are the property of their respective owners.
            </p>
            <div class="whitespace-nowrap">
              Build
              {' '}
              {commit ? (
                <a
                  href={`https://codeberg.org/ConsentTheater/website/commit/${commit}`}
                  target="_blank"
                  rel="noopener"
                  class="font-mono transition-colors hover:text-foreground"
                >{commit}</a>
              ) : (
                <span class="font-mono">dev</span>
              )}
              {' · '}
              <time datetime={builtAt} class="font-mono">{builtAt}</time>
            </div>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
