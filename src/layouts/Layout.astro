---
import '@/styles/globals.css';
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { execSync } from 'node:child_process';
import { SettingsDialog } from '@/components/SettingsDialog';
import logo from '@/assets/logo.png';

function readBuildInfo() {
  const builtAt = new Date().toISOString().slice(0, 10);
  try {
    const commit = execSync('git rev-parse --short HEAD', {
      encoding: 'utf8',
      stdio: ['ignore', 'pipe', 'ignore']
    }).trim();
    return { commit, builtAt };
  } catch {
    return { commit: null as string | null, builtAt };
  }
}

const { commit, builtAt } = readBuildInfo();

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'ConsentTheater — GDPR cookie & tracker lookup',
  description = 'Identify cookies, domains and trackers. Look up any cookie name or domain to see the company, service, category and severity.',
  image = '/og-default.png'
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const imageUrl = new URL(image, Astro.site).toString();

const year = new Date().getFullYear();

const currentPath = Astro.url.pathname;
const navItems = [
  { href: '/', label: 'Lookup', mobileLabel: 'Check an Actor', mobileOnly: true },
  { href: '/methodology/', label: 'Methodology', mobileLabel: 'Our Methodology' },
  { href: '/extension/', label: 'Extension', mobileLabel: 'Free Browser Extension' },
  { href: '/about/', label: 'About', mobileLabel: 'About Project' }
];
const isActive = (href: string) =>
  href === '/'
    ? currentPath === '/'
    : currentPath === href || currentPath.startsWith(href);
---
<!doctype html>
<html lang="en" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="ConsentTheater" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="628" />
    <meta property="og:image:alt" content={title} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={title} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="ConsentTheater" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#24488f" />
    <meta name="color-scheme" content="light dark" />
    <script is:inline>
      (function () {
        try {
          var raw = localStorage.getItem('ct_settings');
          var s = raw ? JSON.parse(raw) : {};
          var theme = s.theme || 'system';
          var dark = theme === 'dark' ||
            (theme === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
          if (dark) document.documentElement.classList.add('dark');

          var hc = s.highContrast;
          if (hc === true) hc = 'on';
          else if (hc === false) hc = 'off';
          else if (hc == null) hc = 'system';
          var useHc = hc === 'on' ||
            (hc === 'system' && window.matchMedia('(prefers-contrast: more)').matches);
          if (useHc) document.documentElement.classList.add('high-contrast');
        } catch (e) { /* localStorage unavailable — fall back to defaults */ }
      })();
    </script>
  </head>
  <body class="min-h-full bg-background text-foreground">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2"
    >
      Skip to main content
    </a>
    <div class="flex min-h-screen flex-col">
      <header class="border-b border-border bg-card">
        <div class="mx-auto flex w-full max-w-4xl items-center justify-between gap-3 px-6 py-4">
          <a href="/" class="group flex items-center gap-3" aria-label="ConsentTheater home">
            <Image
              src={logo}
              alt=""
              width={36}
              height={36}
              densities={[2, 3]}
              loading="eager"
              class="h-9 w-9 rounded-full"
              aria-hidden="true"
            />
            <div class="leading-tight transition-opacity group-hover:opacity-80">
              <p class="font-display text-base font-bold tracking-tight">ConsentTheater</p>
              <p class="text-[11px] font-semibold uppercase tracking-wider text-muted-foreground">Tracker lookup</p>
            </div>
          </a>

          <div class="flex items-center gap-8">
            <nav aria-label="Primary" class="hidden sm:block">
              <ul class="flex items-center gap-5">
                {navItems.filter(item => !item.mobileOnly).map(item => (
                  <li>
                    <a
                      href={item.href}
                      class:list={[
                        'text-sm transition-colors hover:text-foreground',
                        isActive(item.href) ? 'font-semibold text-foreground' : 'text-muted-foreground'
                      ]}
                      aria-current={isActive(item.href) ? 'page' : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>

            <SettingsDialog client:load navItems={navItems} currentPath={currentPath} />
          </div>
        </div>
      </header>

      <main id="main" class="flex-1">
        <slot />
      </main>

      <footer class="border-t border-border bg-card">
        <div class="mx-auto flex w-full max-w-4xl flex-col items-start gap-6 px-6 py-6 text-[11px] text-muted-foreground min-[900px]:flex-row min-[900px]:flex-wrap min-[900px]:items-center min-[900px]:justify-between min-[900px]:gap-y-2 min-[900px]:py-3">
          <!-- 1. Menu -->
          <nav
            class="flex flex-col items-start gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:gap-x-5 sm:gap-y-2 min-[900px]:order-2 min-[900px]:gap-x-4"
            aria-label="Footer"
          >
            <a href="/about/" class="py-1 transition-colors hover:text-foreground min-[900px]:py-0">About</a>
            <a href="/extension/" class="py-1 transition-colors hover:text-foreground min-[900px]:py-0">Extension</a>
            <a href="/methodology/" class="py-1 transition-colors hover:text-foreground min-[900px]:py-0">Methodology</a>
            <a href="/privacy/" class="py-1 transition-colors hover:text-foreground min-[900px]:py-0">Privacy</a>
            <a href="/license/" class="py-1 transition-colors hover:text-foreground min-[900px]:py-0">License</a>
            <a
              href="https://github.com/ConsentTheater"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 py-1 transition-colors hover:text-foreground min-[900px]:py-0"
              aria-label="ConsentTheater on GitHub"
            >
              <Icon name="ph:github-logo" class="h-3.5 w-3.5" aria-hidden="true" />
              GitHub
            </a>
          </nav>

          <!-- 2. Copyright -->
          <span class="min-[900px]:order-1">
            © {year} ConsentTheater · Non-commercial, open-source project <span class="whitespace-nowrap">(AGPL-3.0)</span>
          </span>

          <!-- 3. Build -->
          <div class="text-[10px] text-muted-foreground/70 min-[900px]:order-3 min-[900px]:basis-full">
            <span class="whitespace-nowrap">
              Build
              {' '}
              {commit ? (
                <a
                  href={`https://github.com/ConsentTheater/website/commit/${commit}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-mono transition-colors hover:text-foreground"
                >{commit}</a>
              ) : (
                <span class="font-mono">dev</span>
              )}
              {' · '}
              <time datetime={builtAt} class="font-mono">{builtAt}</time>
            </span>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
