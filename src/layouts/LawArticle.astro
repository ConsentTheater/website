---
import Layout from '@/layouts/Layout.astro';

interface Props {
  regulation: string;          // e.g. "GDPR" / "ePrivacy Directive"
  articleLabel: string;        // e.g. "Article 6"
  title: string;               // e.g. "Lawfulness of processing"
  eurLexUrl: string;           // canonical EU source
  citation: string;            // formal citation, e.g. "Regulation (EU) 2016/679"
  updated: string;             // YYYY-MM-DD when last reconciled with eur-lex
  metaTitle?: string;
  metaDescription?: string;
}

const {
  regulation,
  articleLabel,
  title,
  eurLexUrl,
  citation,
  updated,
  metaTitle,
  metaDescription
} = Astro.props;

const fullMetaTitle =
  metaTitle ?? `${regulation} ${articleLabel} — ${title} — ConsentTheater`;
const fullMetaDescription =
  metaDescription ?? `${regulation} ${articleLabel}: ${title}. Plain-language explainer paired with the verbatim official text. Reproduced from ${citation} on eur-lex.europa.eu.`;
---
<Layout title={fullMetaTitle} description={fullMetaDescription}>
  <section class="mx-auto w-full max-w-3xl px-6 pt-10 pb-12">
    <nav class="mb-4 text-[11px] text-muted-foreground" aria-label="Breadcrumb">
      <ol class="flex flex-wrap items-center gap-1">
        <li>
          <a href="/law/" class="link font-semibold uppercase tracking-wider">
            Law references
          </a>
        </li>
        <li aria-hidden="true" class="font-mono">/</li>
        <li class="font-semibold uppercase tracking-wider">{regulation}</li>
        <li aria-hidden="true" class="font-mono">/</li>
        <li class="font-semibold uppercase tracking-wider">{articleLabel}</li>
      </ol>
    </nav>

    <header class="mb-8">
      <p class="text-[11px] font-semibold uppercase tracking-wider text-muted-foreground">
        {regulation} · {articleLabel}
      </p>
      <h1 class="mt-1 font-display text-2xl font-bold tracking-tight sm:text-3xl">
        {title}
      </h1>
      <p class="mt-2 text-[11px] text-muted-foreground">
        Last reconciled with the canonical source <time datetime={updated} class="font-mono">{updated}</time>
      </p>
    </header>

    <div class="space-y-10 text-sm leading-relaxed text-foreground/90">

      <section id="plain-language">
        <h2 class="mb-3 font-display text-lg font-bold tracking-tight">In plain language</h2>
        <slot name="summary" />
      </section>

      <section id="how-we-use">
        <h2 class="mb-3 font-display text-lg font-bold tracking-tight">How we use this on consenttheater.org</h2>
        <slot name="crossrefs" />
      </section>

      <section id="original-text" aria-labelledby="original-text-heading">
        <h2 id="original-text-heading" class="mb-2 font-display text-lg font-bold tracking-tight">
          Original text
        </h2>
        <p class="mb-4 text-xs text-muted-foreground">
          Reproduced verbatim from <em>{citation}</em>, published by the Publications
          Office of the European Union on
          <a href={eurLexUrl} target="_blank" rel="noopener" class="link">eur-lex.europa.eu</a>.
          The official source is authoritative; this rendering is a navigation
          convenience.
        </p>
        <blockquote
          cite={eurLexUrl}
          class="border-l-2 border-border bg-card px-5 py-4 text-sm leading-relaxed text-foreground/90"
        >
          <slot name="text" />
        </blockquote>
        <p class="mt-3 text-xs text-muted-foreground">
          Prefer the canonical version?
          <a href={eurLexUrl} target="_blank" rel="noopener" class="link">
            Open this article on eur-lex.europa.eu →
          </a>
        </p>
      </section>

      <section id="attribution">
        <h2 class="mb-2 font-display text-lg font-bold tracking-tight">Reproduction notice</h2>
        <p class="text-xs leading-relaxed text-muted-foreground">
          The text reproduced on this page is taken from the consolidated version of
          <em>{citation}</em>, an official act of the European Union. EU legislative texts
          are excluded from copyright protection (recital 22 of Directive (EU) 2019/790).
          ConsentTheater is not affiliated with, endorsed by, or sponsored by any EU
          institution. For binding legal use always consult the official source on
          <a href={eurLexUrl} target="_blank" rel="noopener" class="link">eur-lex.europa.eu</a>.
          We re-verify each reproduction against the canonical text on the date shown at
          the top of this page.
        </p>
      </section>

    </div>
  </section>
</Layout>
