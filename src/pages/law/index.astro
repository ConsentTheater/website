---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('law');
const articles = all
  .sort((a, b) => {
    const ao = a.data.order ?? Number.POSITIVE_INFINITY;
    const bo = b.data.order ?? Number.POSITIVE_INFINITY;
    if (ao !== bo) return ao - bo;
    return a.data.title.localeCompare(b.data.title);
  })
  .map((e) => ({
    href: `/law/${e.id}/`,
    label: `${e.data.regulation} ${e.data.articleLabel}`,
    title: e.data.title,
    summary: e.data.summary,
    updated: e.data.updated
  }));

const updated = articles
  .map((a) => a.updated)
  .sort()
  .reverse()[0] ?? '';

const ukOverview = {
  href: '/law/uk-gdpr-and-pecr/',
  label: 'UK GDPR & PECR',
  title: 'United Kingdom — same articles, ICO regulator',
  summary:
    'The UK GDPR retains the EU text in domestic law (Schedule I, Data Protection Act 2018), and PECR Regulation 6 carries the cookie rule. Substantively the same articles, enforced by the ICO. This page maps each EU article to its UK counterpart.'
};
---
<Layout
  title="Law references — ConsentTheater"
  description="Plain-language renderings of the GDPR and ePrivacy articles ConsentTheater relies on, with the verbatim official text alongside and a link back to the EU's canonical source."
  markdownUrl="/law.md"
>
  <section class="mx-auto w-full max-w-3xl px-6 pt-10 pb-12">
    <div class="mb-6">
      <p class="text-[11px] font-semibold uppercase tracking-wider text-muted-foreground">
        Law references
      </p>
      <h1 class="mt-1 font-display text-2xl font-bold tracking-tight sm:text-3xl">
        The articles we cite, in plain language
      </h1>
      <p class="mt-2 text-[11px] text-muted-foreground">
        Last updated <time datetime={updated} class="font-mono">{updated}</time>
      </p>
      <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
        ConsentTheater's tracker classifications and policy pages reference a small number
        of EU legal provisions. Each page below pairs a short, plain-language explainer
        with the verbatim official text, and links back to the canonical source on
        <a href="https://eur-lex.europa.eu" target="_blank" rel="noopener" class="link">eur-lex.europa.eu</a>.
        We host these articles for navigation convenience — for any binding legal use,
        always consult the original.
      </p>
    </div>

    <ul class="space-y-4">
      {articles.map((a) => (
        <li>
          <a
            href={a.href}
            class="block border border-border bg-card px-5 py-4 transition-colors hover:bg-secondary"
          >
            <p class="text-[10px] font-semibold uppercase tracking-wider text-muted-foreground">
              {a.label}
            </p>
            <p class="mt-1 font-display text-base font-bold tracking-tight">
              {a.title}
            </p>
            <p class="mt-2 text-sm leading-snug text-foreground/80">
              {a.summary}
            </p>
          </a>
        </li>
      ))}
    </ul>

    <section class="mt-10 border-t border-border pt-6">
      <p class="mb-3 text-[11px] font-semibold uppercase tracking-wider text-muted-foreground">
        Across the channel
      </p>
      <a
        href={ukOverview.href}
        class="block border border-border bg-card px-5 py-4 transition-colors hover:bg-secondary"
      >
        <p class="text-[10px] font-semibold uppercase tracking-wider text-muted-foreground">
          {ukOverview.label}
        </p>
        <p class="mt-1 font-display text-base font-bold tracking-tight">
          {ukOverview.title}
        </p>
        <p class="mt-2 text-sm leading-snug text-foreground/80">
          {ukOverview.summary}
        </p>
      </a>
    </section>

    <div class="mt-10 border-t border-border pt-6 text-xs text-muted-foreground">
      <p>
        Looking for a different article? The full GDPR (99 articles, 173 recitals) and the
        full ePrivacy Directive are available on the EU's legal portal:
      </p>
      <ul class="mt-2 list-disc space-y-1 pl-5">
        <li>
          <a href="https://eur-lex.europa.eu/eli/reg/2016/679/oj" target="_blank" rel="noopener" class="link">
            Regulation (EU) 2016/679 — General Data Protection Regulation
          </a>
        </li>
        <li>
          <a href="https://eur-lex.europa.eu/eli/dir/2002/58/oj" target="_blank" rel="noopener" class="link">
            Directive 2002/58/EC — ePrivacy Directive
          </a>
        </li>
      </ul>
    </div>
  </section>
</Layout>
