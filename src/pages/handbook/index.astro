---
import Layout from '@/layouts/Layout.astro';
import { getCollection } from 'astro:content';
import {
  HANDBOOK_CATEGORY_LABELS,
  HANDBOOK_CATEGORY_ORDER
} from '@/content.config';

const all = await getCollection('handbook', ({ data }) => !data.draft);

const grouped = HANDBOOK_CATEGORY_ORDER.map((cat) => ({
  key: cat,
  label: HANDBOOK_CATEGORY_LABELS[cat],
  entries: all
    .filter((e) => e.data.category === cat)
    .sort((a, b) => {
      const ao = a.data.order ?? Number.POSITIVE_INFINITY;
      const bo = b.data.order ?? Number.POSITIVE_INFINITY;
      if (ao !== bo) return ao - bo;
      return a.data.title.localeCompare(b.data.title);
    })
})).filter((g) => g.entries.length > 0);

const total = all.length;
---
<Layout
  title="Handbook — ConsentTheater"
  description="A practical handbook on GDPR, ePrivacy, consent, tracking and user rights — written as evergreen reference, organised by topic."
>
  <section class="mx-auto w-full max-w-3xl px-6 pt-10 pb-12">
    <header class="mb-10">
      <p class="text-[11px] font-semibold uppercase tracking-wider text-muted-foreground">
        Handbook
      </p>
      <h1 class="mt-1 font-display text-2xl font-bold tracking-tight sm:text-3xl">
        Practical guides to GDPR, ePrivacy and consent
      </h1>
      <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
        Reference articles you can read in any order. Written to stay accurate over
        time — we update individual entries when the law or guidance changes, not on
        a calendar. {total === 0 ? '' : total === 1 ? '1 article so far.' : `${total} articles so far.`}
      </p>
    </header>

    {grouped.length === 0 ? (
      <p class="text-sm text-muted-foreground">
        No articles published yet. Check back soon.
      </p>
    ) : (
      <div class="space-y-12">
        {grouped.map((group) => (
          <section aria-labelledby={`cat-${group.key}`}>
            <h2
              id={`cat-${group.key}`}
              class="font-display text-base font-semibold tracking-tight text-muted-foreground uppercase tracking-wider text-[11px]"
            >
              {group.label}
            </h2>
            <ul class="mt-3 space-y-3">
              {group.entries.map((entry) => (
                <li>
                  <a
                    href={`/handbook/${entry.id}/`}
                    class="block border border-border bg-card px-5 py-4 transition-colors hover:bg-secondary"
                  >
                    <p class="font-display text-base font-bold leading-tight tracking-tight text-foreground">
                      {entry.data.title}
                    </p>
                    <p class="mt-2 text-sm leading-snug text-foreground/80">
                      {entry.data.summary}
                    </p>
                    <p class="mt-2 text-[11px] text-muted-foreground">
                      Updated <time datetime={entry.data.updated} class="font-mono">{entry.data.updated}</time>
                    </p>
                  </a>
                </li>
              ))}
            </ul>
          </section>
        ))}
      </div>
    )}
  </section>
</Layout>
