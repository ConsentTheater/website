---
import Layout from '@/layouts/Layout.astro';
---
<Layout
  title="404 — Page not found — ConsentTheater"
  description="The page you're looking for doesn't exist."
>
  <section class="mx-auto flex min-h-[60vh] w-full max-w-2xl flex-col items-center justify-center px-6 py-16 text-center">
    <p
      aria-hidden="true"
      class="font-display text-[clamp(5rem,15vw,10rem)] font-bold leading-none text-foreground/10 select-none"
    >
      404
    </p>
    <h1 class="mt-2 font-display text-2xl font-bold tracking-tight sm:text-3xl">
      Page not found
    </h1>
    <p class="mt-3 max-w-md text-sm leading-relaxed text-muted-foreground">
      This page doesn't exist, or it's been moved. Head back to the homepage
      to look up a cookie, domain, or company.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex h-10 items-center justify-center border border-primary bg-primary px-6 text-sm font-medium text-primary-foreground transition-opacity hover:opacity-90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
    >
      Back to home
    </a>
  </section>
</Layout>
